                    alert.style.display = 'none';
                }, 10000); // Le message de succès disparaît après 10 secondes
            });
            if (alertError) {
                setTimeout(() => {
                    alertError.style.display = 'none';
                }, 10000); // Le message d'erreur disparaît après 10 secondes
            }
        });
